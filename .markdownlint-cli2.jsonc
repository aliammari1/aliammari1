{
  // Profile README is inline-HTML heavy and long-lined by design.
  "config": {
    "default": true,
    "MD013": false, // line length — badges/URLs are long
    "MD033": false, // inline HTML — required for centered profile layout
    "MD041": false, // first line need not be a top-level heading (HTML banner)
    "MD034": false  // bare URLs inside HTML attributes
  },
  "globs": ["**/*.md"],
  "ignores": ["profile-3d-contrib/**", "node_modules/**"]
}
